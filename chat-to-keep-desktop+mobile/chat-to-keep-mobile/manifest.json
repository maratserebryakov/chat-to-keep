{
  "manifest_version": 2,
  "name": "Chat to Keep",
  "version": "1.2",
  "description": "Save RouterAI chat to GitHub Gist",
  "permissions": ["activeTab", "storage"],
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  },
  "browser_action": {
    "default_title": "Chat to Keep",
    "default_icon": "icon.png"
  },
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "content_scripts": [{
    "matches": ["*://*.routerai.ru/*"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }]
}